APP_NAME="補習班管理系統"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# 本地開發用 SQLite（不需任何設定，php artisan migrate 會自動建檔）
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# === 部署用 PostgreSQL / Supabase ===
# 上線時把上面的 DB_CONNECTION 改成 pgsql，並填入 Supabase 的連線資訊：
# DB_CONNECTION=pgsql
# DB_HOST=aws-0-xxx.pooler.supabase.com
# DB_PORT=6543
# DB_DATABASE=postgres
# DB_USERNAME=postgres.xxxxxxxx
# DB_PASSWORD=你的Supabase資料庫密碼

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# 本地用 public（php artisan storage:link 後照片可公開存取）；上線改成 s3 接 Supabase Storage
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# === 上線照片儲存（Supabase Storage，S3 相容）===
# 在 Supabase → Storage 建一個 bucket，再到 Project Settings → Storage 取得 S3 憑證
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=true
# AWS_ENDPOINT=https://xxxxxxxx.supabase.co/storage/v1/s3

VITE_APP_NAME="${APP_NAME}"
